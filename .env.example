# ESV Bible API key (required for English text)
# Get one at https://api.esv.org/
ESV_API_KEY=

# NKRV Bible backend API URL (bible-agent FastAPI service)
# Dev default: http://localhost:8080
# Set to deployed URL in production (e.g. https://your-api.vercel.app)
NKRV_API_URL=

# Homework submission recipient email (used by mailto on 숙제보기 page)
PUBLIC_HOMEWORK_SUBMIT_EMAIL=
